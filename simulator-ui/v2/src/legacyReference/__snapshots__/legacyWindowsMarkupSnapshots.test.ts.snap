// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Legacy windows reference — markup snapshots > ClearingPanel 1`] = `"<div class="ds-ov-panel ds-panel ds-panel--elevated" style="position: static; left: auto; top: auto; right: auto; z-index: auto;" data-testid="clearing-panel" aria-label="Clearing panel"><div class="ds-panel__header"><div class="ds-h2"><span>Run clearing</span><span class="ds-muted ds-mono"> (ESC to close)</span></div></div><div class="ds-panel__body ds-stack"><div class="ds-label cp-equivalent-row"><span>Equivalent:</span><span class="ds-mono">UAH</span></div><!--v-if--><div class="ds-help" data-testid="clearing-confirm-help">This will run a clearing cycle in backend.</div><div class="ds-row ds-row--actions cp-actions"><button class="ds-btn ds-btn--primary" type="button">Confirm</button><button class="ds-btn ds-btn--ghost" type="button">Cancel</button></div><!--v-if--></div></div>"`;

exports[`Legacy windows reference — markup snapshots > EdgeDetailPopup 1`] = `"<div class="popup ds-ov-item ds-ov-surface ds-ov-edge-detail" data-testid="edge-detail-popup" aria-label="Edge detail popup" style="position: static; left: auto; top: auto; right: auto; z-index: auto;"><div class="popup__title ds-label">Edge</div><div class="popup__subtitle ds-value ds-mono">alice → bob</div><div class="popup__grid"><div class="ds-label">Used</div><div class="ds-value ds-mono">12 UAH</div><div class="ds-label">Limit</div><div class="ds-value ds-mono">100 UAH</div><div class="ds-label">Available</div><div class="ds-value ds-mono">88 UAH</div><div class="ds-label">Status</div><div class="ds-value ds-mono">active</div></div><!-- ED-2: capacity utilization bar (used/limit), shown under the stats grid. --><div class="popup__util" aria-label="Utilization"><div class="popup__util-bar" role="progressbar" aria-label="Utilization bar" aria-valuenow="12" aria-valuetext="12%" aria-valuemin="0" aria-valuemax="100"><div class="popup__util-fill" style="width: 12%; background: var(--ds-ok);"></div></div><div class="popup__util-pct ds-label ds-mono" data-testid="edge-utilization-pct">12%</div></div><div class="popup__actions"><div class="popup__inline-warn ds-label ds-mono" data-testid="edge-close-blocked"> Cannot close: trustline has outstanding debt (used: 12 UAH). Reduce debt to 0 first. </div><button class="ds-btn ds-btn--secondary ds-btn--sm" type="button" data-testid="edge-send-payment"> 💸 Pay alice</button><button class="ds-btn ds-btn--secondary ds-btn--sm" type="button"> Change limit </button><button class="ds-btn ds-btn--danger ds-btn--sm" type="button" disabled="" data-testid="edge-close-line-btn">Close line</button><!--v-if--><button class="ds-btn ds-btn--ghost ds-btn--sm" type="button">Close</button></div></div>"`;

exports[`Legacy windows reference — markup snapshots > ManualPaymentPanel 1`] = `"<div class="ds-ov-panel ds-ov-panel--compact ds-panel ds-panel--elevated" style="position: static; left: auto; top: auto; right: auto; z-index: auto;" data-testid="manual-payment-panel" aria-label="Manual payment panel"><div class="ds-panel__header"><div class="ds-h2">Manual payment: alice → bob <span class="ds-muted ds-mono"> (ESC to close)</span></div></div><div class="ds-panel__body ds-stack"><div class="ds-controls__row ds-controls__row--compact"><label class="ds-label" for="mp-from">From</label><select id="mp-from" class="ds-select" aria-label="From participant" value="alice"><option value="">—</option><option value="alice">Alice (alice)</option><option value="bob">Bob (bob)</option><option value="carol">Carol (carol)</option></select></div><div class="ds-controls__row ds-controls__row--compact"><label class="ds-label" for="mp-to"> To <!--v-if--></label><select id="mp-to" class="ds-select" aria-label="To participant" aria-describedby="mp-to-help" value="bob"><option value="">—</option><option value="bob">Bob (bob) — …</option><option value="carol">Carol (carol) — …</option></select></div><!--v-if--><div id="mp-to-help" class="ds-help mp-to-help" data-testid="manual-payment-to-help" style="display: none;"></div><!--v-if--><!--v-if--><div class="ds-row ds-row--space"><div class="ds-label">Direct capacity</div><div class="ds-value ds-mono">88 UAH</div></div><div class="ds-help ds-muted" data-testid="mp-direct-capacity-help"> Direct capacity is a 1-hop hint. Recipients list is backend-routed (multi-hop, max hops: 6). </div><div class="ds-controls__row ds-controls__row--compact"><label class="ds-label" for="mp-amount">Amount</label><div class="ds-controls__suffix mp-amount-row"><input id="mp-amount" class="ds-input ds-mono mp-amount-input" type="text" inputmode="decimal" autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false" placeholder="0.00" aria-invalid="false" aria-describedby="mp-amount-help"><span class="ds-label ds-muted">UAH</span></div></div><!-- Keep stable aria-describedby target (UX-9), but show content only when disabled. --><div id="mp-amount-help" class="mp-confirm-help"><div class="ds-help" data-testid="mp-confirm-reason">Enter a positive amount.</div></div><!--v-if--><div class="ds-row ds-row--actions mp-actions"><button class="ds-btn ds-btn--primary" type="button" data-testid="manual-payment-confirm" disabled="">Confirm</button><button class="ds-btn ds-btn--ghost" type="button" data-testid="manual-payment-cancel"> Cancel </button></div></div></div>"`;

exports[`Legacy windows reference — markup snapshots > NodeCardOverlay 1`] = `"<div class="ds-ov-node-card" style="position: static; left: auto; top: auto; right: auto; z-index: auto;"><div class="ds-panel ds-panel--elevated"><div class="ds-panel__body ds-ov-node-card__body"><!-- Identity + Balance (merged) ------------------------------------><div class="ds-ov-node-card__identity"><div class="ds-node-card__avatar ds-ov-node-card__avatar">BO</div><div class="ds-ov-node-card__text"><div class="ds-node-card__name">Bob</div><div class="ds-node-card__meta">person · active</div></div><div class="ds-ov-node-card__right"><div class="ds-ov-node-card__service"><button class="ds-btn ds-btn--ghost ds-btn--icon ds-ov-node-card__action-btn" type="button" aria-label="Pin" title="Pin">◇</button><button class="ds-btn ds-btn--ghost ds-btn--icon ds-ov-node-card__action-btn" type="button" aria-label="Close" title="Close"> × </button></div><div class="ds-ov-node-card__balance" style="color: #94a3b8;">42</div></div></div><!-- Separator --------------------------------------------------------><hr class="ds-ov-node-card__divider"><!-- Stats (only unique fields: Out, In, Degree) ----------------------><div class="ds-ov-node-card__stats"><div class="ds-ov-node-card__stat"><span class="ds-label">Out</span><span class="ds-value ds-mono">100</span></div><div class="ds-ov-node-card__stat"><span class="ds-label">In</span><span class="ds-value ds-mono">50</span></div><div class="ds-ov-node-card__stat"><span class="ds-label">Degree</span><span class="ds-value ds-mono">3</span></div></div><!-- BUG-1: Interact Mode Trustlines section ---------------------------><hr class="ds-ov-node-card__divider"><!-- Quick-action buttons --><div class="nco-interact-actions"><button class="ds-btn ds-btn--primary ds-btn--sm" type="button" data-testid="node-card-send-payment"> 💸 Send Payment </button><button class="ds-btn ds-btn--secondary ds-btn--sm" type="button" data-testid="node-card-new-trustline"> ＋ New Trustline </button></div><!-- Trustlines list: grouped OUT / IN --><div class="nco-trustlines"><!-- OUT group --><div class="nco-tl-group-header">OUT → 1</div><div class="nco-trustline-row" title="avail: 88"><span class="nco-trustline-row__peer ds-mono">Alice</span><span class="nco-trustline-row__amounts ds-mono">12 / 100</span><span class="nco-trustline-row__avail ds-mono">avail: 88</span><button class="ds-btn ds-btn--ghost ds-btn--icon nco-trustline-row__edit" type="button" title="Edit trustline" aria-label="Edit trustline">✏️</button></div><!-- IN group --><div class="nco-tl-group-header nco-tl-group-header--gap">IN ← 0</div></div></div></div></div>"`;

exports[`Legacy windows reference — markup snapshots > TrustlineManagementPanel 1`] = `"<div class="ds-ov-panel ds-ov-panel--compact ds-panel ds-panel--elevated" style="position: static; left: auto; top: auto; right: auto; z-index: auto;" data-testid="trustline-panel" aria-label="Trustline management panel"><div class="ds-panel__header"><div class="ds-h2">Trustline: alice → bob <span class="ds-muted ds-mono"> (ESC to close)</span></div></div><div class="ds-panel__body ds-stack"><!--v-if--><!--v-if--><div class="ds-controls__row ds-controls__row--compact"><label class="ds-label" for="tl-pick">Existing</label><select id="tl-pick" class="ds-select" title="Available only in edit/create mode" aria-label="Pick existing trustline" value="alice|bob"><option value="">—</option><option value="alice|bob">Alice → Bob</option></select></div><!--v-if--><!--v-if--><div class="tl-stats" aria-label="Trustline stats"><div class="tl-stats__item"><div class="ds-label">Used</div><div class="ds-value ds-mono">12 UAH</div></div><div class="tl-stats__item"><div class="ds-label">Limit</div><div class="ds-value ds-mono">100 UAH</div></div><div class="tl-stats__item"><div class="ds-label">Available</div><div class="ds-value ds-mono">88 UAH</div></div></div><!--v-if--><!--v-if--><div class="ds-controls__row ds-controls__row--compact"><label class="ds-label" for="tl-new-limit">New limit</label><div class="ds-controls__suffix tl-input-row"><input id="tl-new-limit" class="ds-input ds-mono tl-limit-input" type="text" inputmode="decimal" autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false" placeholder="0.00" aria-invalid="false"><span class="ds-label ds-muted">UAH</span></div></div><!--v-if--><!--v-if--><!--v-if--><div class="ds-alert ds-alert--warn ds-mono" data-testid="tl-close-blocked"> Cannot close: trustline has outstanding debt (used: 12 UAH). Reduce debt to 0 first. </div><div class="ds-row ds-row--actions tl-actions"><button class="ds-btn ds-btn--primary" type="button">Update</button><button class="ds-btn" type="button" disabled="" data-testid="trustline-close-btn">Close TL</button><!--v-if--><button class="ds-btn ds-btn--ghost" type="button">Cancel</button></div></div></div>"`;
